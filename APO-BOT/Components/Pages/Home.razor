@page "/"
@inject IApoBotApiClient Api

<PageTitle>Inicio - APObot</PageTitle>

<div class="home-screen">
    <section class="home-column home-left">
        <MudPaper Class="capacity-card" Elevation="0">
            <div class="capacity-copy">
                <h1>Capacidad<br />de almacenamiento</h1>
                <div class="capacity-state">
                    <span>Estado</span>
                    <strong>@(dashboard?.Capacity.Status ?? "Sin datos")@if (!string.IsNullOrWhiteSpace(dashboard?.Capacity.StatusDetail)) { <small>&nbsp;(@dashboard.Capacity.StatusDetail)</small> }</strong>
                </div>
                <p class="eyebrow arrow-label">Ultimas entradas</p>
                @if (dashboard?.RecentEntries.Count > 0)
                {
                    <ul>
                        @foreach (var item in dashboard.RecentEntries.Take(4))
                        {
                            <li><strong>@FormatQuantity(item.Quantity)</strong><span>@item.ProductDescription</span></li>
                        }
                    </ul>
                }
                else
                {
                    <BackendState Loading="loading" Error="@error" Compact="true" Title="Sin entradas" Detail="No hay movimientos recientes." />
                }
            </div>
            <div class="capacity-meter" style="--capacity:@CapacityCssValue" aria-label="@($"Capacidad al {CapacityPercentage} por ciento")">
                <span><strong>@(dashboard is null ? "--" : CapacityPercentage.ToString("0"))</strong>%</span>
            </div>
        </MudPaper>

        <MudPaper Class="camera-card" Elevation="0">
            @if (SelectedCamera is not null)
            {
                <img src="@SelectedCamera.StreamUrl" alt="@SelectedCamera.Name" />
            }
            else
            {
                <div class="camera-placeholder">
                    <img src="/assets/apobot/ilustracion_cajas_balda.svg" alt="" />
                    <BackendState Loading="loading" Error="@error" Inverse="true" Title="Camara no disponible" Detail="La señal se mostrara cuando el backend publique una fuente activa." />
                </div>
            }
            @if (dashboard?.Cameras.Count > 0)
            {
                <div class="camera-selector" aria-label="Seleccion de camara">
                    @foreach (var camera in dashboard.Cameras)
                    {
                        <MudButton Class="@CameraButtonClass(camera)" Variant="Variant.Text" Disabled="@(!camera.Available)" OnClick="() => selectedCameraId = camera.Id"><i></i>@camera.Name</MudButton>
                    }
                </div>
            }
        </MudPaper>
    </section>

    <section class="home-column home-right">
        <MudPaper Class="panel exits-panel" Elevation="0">
            <header class="panel-heading">
                <div class="heading-symbol">▦</div>
                <h2>Ultimas<br />salidas <span>›</span></h2>
                <MudButton Href="/estadisticas" Variant="Variant.Text">Ver salidas</MudButton>
            </header>
            <div class="exit-list">
                @if (dashboard?.RecentDispensations.Count > 0)
                {
                    @foreach (var item in dashboard.RecentDispensations)
                    {
                        <div class="exit-row">
                            <strong>@FormatQuantity(item.Quantity)</strong>
                            <span>@item.ProductDescription</span>
                            <time datetime="@item.DispensedAt.ToString("O")">@item.DispensedAt.ToLocalTime().ToString("HH:mm") H</time>
                        </div>
                    }
                }
                else
                {
                    <BackendState Loading="loading" Error="@error" Compact="true" Title="Sin salidas" Detail="No hay dispensaciones recientes." />
                }
            </div>
        </MudPaper>

        <MudPaper Class="alerts-card" Elevation="0" id="avisos">
            <div class="alerts-count">
                <div><span>!</span><strong>@(dashboard?.Alerts.Count(alert => !alert.Resolved).ToString() ?? "--")</strong></div>
                <h2>Avisos</h2>
            </div>
            @if (ActiveAlerts.Count > 0)
            {
                <ul>
                    @foreach (var alert in ActiveAlerts.Take(3))
                    {
                        <li><MudIconButton Icon="@Icons.Material.Rounded.Check" Disabled="@actionPending" aria-label="Marcar aviso como resuelto" OnClick="() => ResolveAlertAsync(alert.Id)" /><span>@alert.Message</span>@if (!string.IsNullOrWhiteSpace(alert.Location)) { <strong>@alert.Location</strong> }</li>
                    }
                </ul>
            }
            else
            {
                <BackendState Loading="loading" Error="@error" Compact="true" Inverse="true" Title="Sin avisos" Detail="No hay alertas activas." />
            }
        </MudPaper>

        <MudPaper Class="panel priority-card" Elevation="0">
            <h2>Nivel de prioridad</h2>
            <div class="priority-options">
                @foreach (var priority in PriorityOptions)
                {
                    <MudButton Class="@PriorityButtonClass(priority.Mode)" Variant="Variant.Filled" Disabled="@(dashboard is null || actionPending)" OnClick="() => SetPriorityAsync(priority.Mode)">
                        <span aria-hidden="true">@priority.Rank</span>@priority.Label
                    </MudButton>
                }
            </div>
        </MudPaper>
    </section>
</div>

@code {
    private static readonly (PriorityMode Mode, string Label, int Rank)[] PriorityOptions =
    [
        (PriorityMode.Load, "Cargar", 2),
        (PriorityMode.Dispense, "Dispensar", 1),
        (PriorityMode.Optimize, "Optimizar", 3)
    ];

    private DashboardDto? dashboard;
    private string? selectedCameraId;
    private bool loading = true;
    private bool actionPending;
    private string? error;

    private decimal CapacityPercentage => Math.Clamp(dashboard?.Capacity.Percentage ?? 0, 0, 100);
    private string CapacityCssValue => $"{CapacityPercentage.ToString("0.##", CultureInfo.InvariantCulture)}%";
    private IReadOnlyList<AlertDto> ActiveAlerts => dashboard?.Alerts.Where(alert => !alert.Resolved).ToArray() ?? [];
    private CameraFeedDto? SelectedCamera => dashboard?.Cameras.FirstOrDefault(camera => camera.Id == selectedCameraId && camera.Available);
    private string CameraButtonClass(CameraFeedDto camera) => selectedCameraId == camera.Id ? "camera-active" : string.Empty;
    private string PriorityButtonClass(PriorityMode mode) => $"priority-option {(dashboard?.PriorityMode == mode ? "priority-selected" : string.Empty)}";

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        loading = true;
        error = null;
        try
        {
            dashboard = await Api.GetDashboardAsync();
            selectedCameraId = dashboard.Cameras.FirstOrDefault(camera => camera.Available)?.Id;
        }
        catch (ApiException exception)
        {
            dashboard = null;
            error = exception.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ResolveAlertAsync(string alertId)
    {
        actionPending = true;
        try
        {
            await Api.ResolveAlertAsync(alertId);
            await LoadDashboardAsync();
        }
        catch (ApiException exception)
        {
            error = exception.Message;
        }
        finally
        {
            actionPending = false;
        }
    }

    private async Task SetPriorityAsync(PriorityMode mode)
    {
        actionPending = true;
        try
        {
            await Api.SetPriorityModeAsync(mode);
            await LoadDashboardAsync();
        }
        catch (ApiException exception)
        {
            error = exception.Message;
        }
        finally
        {
            actionPending = false;
        }
    }

    private static string FormatQuantity(int quantity) => quantity == 1 ? "1 ud." : $"{quantity} uds.";
}
