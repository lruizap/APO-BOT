@page "/ajustes"
@inject IApoBotApiClient Api
@inject NavigationManager Navigation

<PageTitle>Ajustes - APObot</PageTitle>

<div class="settings-screen">
    <header class="screen-title settings-title">
        <img src="/assets/apobot/icon_7_ajustes.svg" alt="" />
        <div>
            <h1>Ajustes</h1>
            <p>Configuracion del display APObot</p>
        </div>
    </header>

    @if (preferences is not null)
    {
        <EditForm Model="preferences" OnValidSubmit="SaveAsync" class="settings-form">
            <MudPaper Class="panel settings-panel settings-identity" Elevation="0">
                <h2>Identificacion</h2>
                <MudTextField T="string" Label="Farmacia" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="preferences.PharmacyName" />
                <MudTextField T="string" Label="Usuario mostrado" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="preferences.UserDisplayName" />
            </MudPaper>

            <MudPaper Class="panel settings-panel" Elevation="0">
                <h2>Pantalla</h2>
                <div class="range-setting">
                    <span>Brillo <strong>@preferences.ScreenBrightness%</strong></span>
                    <MudSlider T="int" Min="20" Max="100" Step="5" Color="Color.Primary" @bind-Value="preferences.ScreenBrightness" />
                </div>
                <MudSelect T="int" Label="Actualizacion de datos" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="preferences.RefreshIntervalSeconds">
                    <MudSelectItem T="int" Value="15">Cada 15 segundos</MudSelectItem>
                    <MudSelectItem T="int" Value="30">Cada 30 segundos</MudSelectItem>
                    <MudSelectItem T="int" Value="60">Cada minuto</MudSelectItem>
                    <MudSelectItem T="int" Value="300">Cada 5 minutos</MudSelectItem>
                </MudSelect>
            </MudPaper>

            <MudPaper Class="panel settings-panel settings-notifications" Elevation="0">
                <div>
                    <h2>Avisos sonoros</h2>
                    <p>Reproducir una señal cuando el sistema reciba un aviso.</p>
                </div>
                <MudSwitch T="bool" Class="switch-control" Color="Color.Primary" @bind-Value="preferences.AlertSoundEnabled">
                    @(preferences.AlertSoundEnabled ? "Activados" : "Desactivados")
                </MudSwitch>
            </MudPaper>

            <footer class="settings-actions">
                <p class="settings-message" role="status">@message</p>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@saving" StartIcon="@Icons.Material.Rounded.Save">@(saving ? "Guardando" : "Guardar ajustes")</MudButton>
            </footer>
        </EditForm>
    }
    else
    {
        <MudPaper Class="panel settings-loading" Elevation="0">
            <BackendState Loading="loading" Error="@error" Title="Ajustes no disponibles" Detail="No se ha podido obtener la configuracion del backend." />
        </MudPaper>
    }
</div>

@code {
    private SystemPreferencesDto? preferences;
    private bool loading = true;
    private bool saving;
    private string? error;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            preferences = await Api.GetSystemPreferencesAsync();
        }
        catch (ApiException exception)
        {
            error = exception.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (preferences is null)
        {
            return;
        }

        saving = true;
        message = null;
        try
        {
            preferences = await Api.UpdateSystemPreferencesAsync(new UpdateSystemPreferencesRequest
            {
                PharmacyName = preferences.PharmacyName,
                UserDisplayName = preferences.UserDisplayName,
                AlertSoundEnabled = preferences.AlertSoundEnabled,
                ScreenBrightness = preferences.ScreenBrightness,
                RefreshIntervalSeconds = preferences.RefreshIntervalSeconds
            });
            message = "Ajustes guardados correctamente.";
            Navigation.Refresh(forceReload: true);
        }
        catch (ApiException exception)
        {
            message = exception.Message;
        }
        finally
        {
            saving = false;
        }
    }
}
