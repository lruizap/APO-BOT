@page "/stock"
@inject IApoBotApiClient Api

<PageTitle>Stock - APObot</PageTitle>

<div class="stock-screen">
    <section class="stock-workspace">
        <MudPaper Class="@ProductListClass" Elevation="0">
            <div class="product-table-head">
                <span class="mobile-stock-filter-label">Buscar por descripcion</span>
                <MudTextField T="string" Label="Codigo" Variant="Variant.Text" Margin="Margin.Dense" Immediate="true" DebounceInterval="300" @bind-Value="query.Code" @bind-Value:after="LoadStockAsync" />
                <MudTextField T="string" Class="active-filter" Label="Descripcion" Placeholder="Buscar por descripcion" Variant="Variant.Text" Margin="Margin.Dense" Immediate="true" DebounceInterval="300" @bind-Value="query.Description" @bind-Value:after="LoadStockAsync" />
                <MudTextField T="string" Label="Categoria" Variant="Variant.Text" Margin="Margin.Dense" Immediate="true" DebounceInterval="300" @bind-Value="query.Category" @bind-Value:after="LoadStockAsync" />
                <MudNumericField T="int?" Label="Stock" Variant="Variant.Text" Margin="Margin.Dense" Min="0" HideSpinButtons="true" Immediate="true" DebounceInterval="300" @bind-Value="query.MinimumStock" @bind-Value:after="LoadStockAsync" />
                <MudTextField T="string" Label="Observaciones" Variant="Variant.Text" Margin="Margin.Dense" Immediate="true" DebounceInterval="300" @bind-Value="query.Observation" @bind-Value:after="LoadStockAsync" />
            </div>
            <div class="product-list">
                @if (stock.Items.Count > 0)
                {
                    @foreach (var product in stock.Items)
                    {
                        <MudButton Class="@ProductRowClass(product)" Variant="Variant.Text" OnClick="() => SelectProductAsync(product)">
                            <strong>@product.Code</strong>
                            <span>@product.Description</span>
                            <span>@product.Category</span>
                            <span class="@(product.Stock == 0 ? "text-coral" : "")">@FormatQuantity(product.Stock)</span>
                            <span class="product-note @(!string.IsNullOrWhiteSpace(product.Observation) ? "product-warning" : "")">
                                @if (!string.IsNullOrWhiteSpace(product.Observation))
                                {
                                    <b>@product.Observation</b>
                                }
                                @if (product.CanOrder)
                                {
                                    <i>Hacer pedido</i>
                                }
                            </span>
                        </MudButton>
                    }
                }
                else
                {
                    <BackendState Loading="stockLoading" Error="@stockError" Title="Sin productos" Detail="El inventario se mostrara cuando el backend devuelva resultados." />
                }
            </div>
        </MudPaper>

        @if (selectedProduct is not null)
        {
            <MudPaper Class="panel stock-units-panel" Elevation="0">
                <div class="data-table-wrap">
                    <table class="data-table stock-units-table">
                        <thead>
                            <tr><th>Id</th><th>Modulo</th><th>Balda</th><th>Pos. X</th><th>Pos. Y</th><th>F. caducidad</th><th>F. carga</th><th>Lote</th><th>Nº serie</th><th>Acciones</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var unit in units)
                            {
                                <tr>
                                    <td class="cyan-cell">@unit.Id</td><td>@unit.Module</td><td>@unit.Shelf</td><td>@unit.PositionX</td><td>@unit.PositionY</td><td>@unit.ExpirationDate?.ToString("MM/yyyy")</td><td>@unit.LoadedAt?.ToLocalTime().ToString("dd/MM/yyyy")</td><td>@unit.Batch</td><td>@unit.SerialNumber</td>
                                    <td><MudButton Class="table-link table-link-view" Variant="Variant.Text" OnClick="() => selectedUnit = unit">Ver</MudButton><MudButton Class="table-link table-link-dispense" Variant="Variant.Text" Disabled="@(string.IsNullOrWhiteSpace(selectedOutputId) || dispensePending)" OnClick="() => DispenseUnitAsync(unit.Id)">Dispensar</MudButton></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (units.Count == 0)
                    {
                        <BackendState Loading="detailLoading" Error="@detailError" Compact="true" Title="Sin unidades" Detail="No hay envases asociados al producto." />
                    }
                </div>
            </MudPaper>
        }
    </section>

    <aside class="stock-detail">
        <MudPaper Class="@ProductDetailClass" Elevation="0">
            @if (selectedProduct is null)
            {
                <img src="/assets/apobot/ilustracion_cajas_balda.svg" alt="" />
                <h2>Seleccione<br />producto<br />para mas info</h2>
            }
            else if (detailLoading)
            {
                <BackendState Loading="true" />
            }
            else if (productDetail is not null)
            {
                <div class="product-title">
                    <img src="/assets/apobot/ilustracion_cajas_balda.svg" alt="" />
                    <h1>@productDetail.Description</h1>
                </div>
                <dl class="product-facts">
                    <dt>Proveedor</dt><dd>@productDetail.Supplier</dd>
                    <dt>Categoria</dt><dd>@productDetail.Category</dd>
                    <dt>Facturable SNS</dt><dd>@(productDetail.IsSnsBillable ? "Si" : "No")</dd>
                    <dt>Situacion</dt><dd>@productDetail.Situation</dd>
                    <dt>Cod. nacional</dt><dd>@productDetail.NationalCode</dd>
                    <dt>EAN13</dt><dd>@productDetail.Ean13</dd>
                </dl>
            }
            else
            {
                <BackendState Error="@detailError" Title="Detalle no disponible" Detail="No se ha podido obtener el producto." />
            }
        </MudPaper>

        <div class="dispense-controls @(selectedProduct is null ? "controls-disabled" : "")">
            <MudPaper Class="control-card output-control" Elevation="0">
                <MudSelect T="string" Label="Salida" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="selectedOutputId" Disabled="@(selectedProduct is null || outputsLoading)">
                    <MudSelectItem T="string" Value="@string.Empty">Seleccione una salida</MudSelectItem>
                    @foreach (var output in outputs.Where(output => output.Available))
                    {
                        <MudSelectItem T="string" Value="@output.Id">@output.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>

            <div class="quantity-control" aria-label="Unidades a dispensar">
                <MudIconButton Icon="@Icons.Material.Rounded.Remove" Color="Color.Secondary" OnClick="DecreaseQuantity" Disabled="@(quantity == 0 || selectedProduct is null)" aria-label="Reducir unidades" />
                <strong>@quantity <span>/ @(selectedProduct?.Stock ?? 0)</span></strong>
                <MudIconButton Icon="@Icons.Material.Rounded.Add" Color="Color.Primary" OnClick="IncreaseQuantity" Disabled="@(selectedProduct is null || quantity >= selectedProduct.Stock)" aria-label="Aumentar unidades" />
            </div>

            <fieldset class="control-card priority-control" disabled="@(selectedProduct is null)">
                <legend>Prioridad</legend>
                @foreach (var level in PriorityOptions)
                {
                    <MudButton Class="@PriorityClass(level.Priority)" Variant="Variant.Text" OnClick="() => selectedPriority = level.Priority">@level.Label</MudButton>
                }
            </fieldset>

            <MudButton Class="primary-gradient-button" Variant="Variant.Filled" Color="Color.Primary" OnClick="DispenseAsync" Disabled="@(!CanDispense)" StartIcon="@Icons.Material.Rounded.Send">Dispensar</MudButton>
            @if (!string.IsNullOrWhiteSpace(actionMessage))
            {
                <p class="api-action-message" role="status">@actionMessage</p>
            }
        </div>
    </aside>
</div>

@code {
    private static readonly (DispensationPriority Priority, string Label)[] PriorityOptions =
    [
        (DispensationPriority.High, "Alta"),
        (DispensationPriority.Medium, "Media"),
        (DispensationPriority.Low, "Baja")
    ];

    private readonly StockQuery query = new();
    private PagedResult<ProductSummaryDto> stock = new();
    private IReadOnlyList<StockUnitDto> units = [];
    private IReadOnlyList<OutputDto> outputs = [];
    private ProductSummaryDto? selectedProduct;
    private ProductDetailDto? productDetail;
    private StockUnitDto? selectedUnit;
    private int quantity;
    private string selectedOutputId = string.Empty;
    private DispensationPriority selectedPriority = DispensationPriority.High;
    private bool stockLoading = true;
    private bool detailLoading;
    private bool outputsLoading = true;
    private bool dispensePending;
    private string? stockError;
    private string? detailError;
    private string? actionMessage;

    private bool CanDispense => selectedProduct is not null && quantity > 0 && !string.IsNullOrWhiteSpace(selectedOutputId) && !dispensePending;
    private string ProductListClass => $"panel product-list-panel {(selectedProduct is null ? "product-list-full" : string.Empty)}";
    private string ProductDetailClass => $"panel product-detail-card {(selectedProduct is null ? "product-detail-empty" : string.Empty)}";
    private string ProductRowClass(ProductSummaryDto product) => $"product-row {(selectedProduct?.Id == product.Id ? "product-selected" : string.Empty)}";
    private string PriorityClass(DispensationPriority priority) => selectedPriority == priority ? "selected" : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadStockAsync(), LoadOutputsAsync());
    }

    private async Task LoadStockAsync()
    {
        stockLoading = true;
        stockError = null;
        try
        {
            query.Page = 1;
            stock = await Api.GetStockAsync(query);
        }
        catch (ApiException exception)
        {
            stock = new();
            stockError = exception.Message;
        }
        finally
        {
            stockLoading = false;
        }
    }

    private async Task LoadOutputsAsync()
    {
        outputsLoading = true;
        try
        {
            outputs = await Api.GetOutputsAsync();
        }
        catch (ApiException exception)
        {
            outputs = [];
            actionMessage = exception.Message;
        }
        finally
        {
            outputsLoading = false;
        }
    }

    private async Task SelectProductAsync(ProductSummaryDto product)
    {
        selectedProduct = product;
        productDetail = null;
        selectedUnit = null;
        units = [];
        quantity = 0;
        selectedOutputId = string.Empty;
        detailLoading = true;
        detailError = null;
        actionMessage = null;
        try
        {
            var detailTask = Api.GetProductAsync(product.Id);
            var unitsTask = Api.GetProductUnitsAsync(product.Id);
            await Task.WhenAll(detailTask, unitsTask);
            productDetail = await detailTask;
            units = await unitsTask;
        }
        catch (ApiException exception)
        {
            detailError = exception.Message;
        }
        finally
        {
            detailLoading = false;
        }
    }

    private void IncreaseQuantity()
    {
        if (selectedProduct is not null && quantity < selectedProduct.Stock)
        {
            quantity++;
        }
    }

    private void DecreaseQuantity()
    {
        quantity = Math.Max(0, quantity - 1);
    }

    private async Task DispenseAsync()
    {
        if (!CanDispense || selectedProduct is null)
        {
            return;
        }

        await SendDispensationAsync(quantity, []);
    }

    private async Task DispenseUnitAsync(string unitId)
    {
        if (selectedProduct is null || string.IsNullOrWhiteSpace(selectedOutputId))
        {
            return;
        }

        await SendDispensationAsync(1, [unitId]);
    }

    private async Task SendDispensationAsync(int requestedQuantity, IReadOnlyList<string> unitIds)
    {
        dispensePending = true;
        actionMessage = null;
        try
        {
            var result = await Api.CreateDispensationAsync(new CreateDispensationRequest
            {
                ProductId = selectedProduct!.Id,
                OutputId = selectedOutputId,
                Quantity = requestedQuantity,
                Priority = selectedPriority,
                UnitIds = unitIds
            });
            actionMessage = string.IsNullOrWhiteSpace(result.Status) ? "Dispensacion enviada." : result.Status;
            quantity = 0;
            await LoadStockAsync();
        }
        catch (ApiException exception)
        {
            actionMessage = exception.Message;
        }
        finally
        {
            dispensePending = false;
        }
    }

    private static string FormatQuantity(int value) => value == 1 ? "1 ud." : $"{value} uds.";
}
