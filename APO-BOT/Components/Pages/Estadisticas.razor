@page "/estadisticas"
@inject IApoBotApiClient Api

<PageTitle>Estadisticas - APObot</PageTitle>

<div class="stats-screen">
    <section class="stats-content">
        @if (activeHistory == HistoryType.Capacity)
        {
            <MudPaper Class="panel chart-panel" Elevation="0">
                <header class="chart-heading">
                    <h1>Historico de carga/dispensacion</h1>
                    <div class="chart-legend"><span class="legend-coral">Envases cargados</span><span class="legend-cyan">Envases dispensados</span></div>
                    <div class="period-switch">
                        @foreach (var period in PeriodOptions)
                        {
                            <MudButton Class="@TopPeriodClass(period.Period)" Variant="Variant.Text" OnClick="() => SetTopPeriodAsync(period.Period)">@period.Label</MudButton>
                        }
                    </div>
                </header>
                <BarChart Points="throughputStatistics.Throughput" Loading="topLoading" Error="@topError" AriaLabel="Grafico de envases cargados y dispensados" />
            </MudPaper>

            <MudPaper Class="panel chart-panel capacity-chart-panel" Elevation="0">
                <header class="chart-heading">
                    <h2>Historico de capacidad</h2>
                    <div class="chart-legend"><span class="legend-coral">Envases almacenados</span><span class="legend-cyan">Envases hueco libre</span></div>
                    <div class="period-switch">
                        @foreach (var period in PeriodOptions)
                        {
                            <MudButton Class="@BottomPeriodClass(period.Period)" Variant="Variant.Text" OnClick="() => SetBottomPeriodAsync(period.Period)">@period.Label</MudButton>
                        }
                    </div>
                </header>
                <AreaChart Points="capacityStatistics.Capacity" Loading="bottomLoading" Error="@bottomError" AriaLabel="Grafico del historico de capacidad" />
            </MudPaper>
        }
        else
        {
            <MudPaper Class="panel history-table-panel" Elevation="0">
                <h1>@SuccessfulHistoryTitle</h1>
                <HistoryTable Items="history.Successful.Items" Loading="historyLoading" Error="@historyError" />
            </MudPaper>
            <MudPaper Class="panel history-table-panel" Elevation="0">
                <h2>@RejectedHistoryTitle</h2>
                <HistoryTable Items="history.Rejected.Items" Loading="historyLoading" Error="@historyError" Rejected="true" />
            </MudPaper>
        }
    </section>

    <aside class="history-nav">
        <h2>Historicos</h2>
        @foreach (var option in HistoryOptions)
        {
            <MudButton Class="@HistoryButtonClass(option.Type)" Variant="Variant.Text" OnClick="() => SetHistoryAsync(option.Type)">De @option.Label</MudButton>
        }
    </aside>
</div>

@code {
    private static readonly (HistoryType Type, string Label)[] HistoryOptions =
    [
        (HistoryType.Dispensation, "Dispensacion"),
        (HistoryType.Load, "Carga"),
        (HistoryType.Capacity, "Capacidad"),
        (HistoryType.Article, "Articulo")
    ];

    private static readonly (StatisticsPeriod Period, string Label)[] PeriodOptions =
    [
        (StatisticsPeriod.Days, "Dias"),
        (StatisticsPeriod.Week, "Semana"),
        (StatisticsPeriod.Month, "Mes")
    ];

    private HistoryType activeHistory = HistoryType.Capacity;
    private StatisticsPeriod topPeriod = StatisticsPeriod.Days;
    private StatisticsPeriod bottomPeriod = StatisticsPeriod.Days;
    private HistoryResultDto history = new();
    private CapacityStatisticsDto throughputStatistics = new();
    private CapacityStatisticsDto capacityStatistics = new();
    private bool historyLoading = true;
    private bool topLoading;
    private bool bottomLoading;
    private string? historyError;
    private string? topError;
    private string? bottomError;
    private string TopPeriodClass(StatisticsPeriod period) => topPeriod == period ? "selected" : string.Empty;
    private string BottomPeriodClass(StatisticsPeriod period) => bottomPeriod == period ? "selected" : string.Empty;
    private string HistoryButtonClass(HistoryType type) => activeHistory == type ? "selected" : string.Empty;

    private string SuccessfulHistoryTitle => activeHistory switch
    {
        HistoryType.Dispensation => "Historico de envases dispensados",
        HistoryType.Load => "Historico de envases cargados",
        HistoryType.Article => "Historico por articulo",
        _ => "Historico"
    };

    private string RejectedHistoryTitle => activeHistory switch
    {
        HistoryType.Dispensation => "Historico de envases no dispensados",
        HistoryType.Load => "Historico de envases no cargados",
        HistoryType.Article => "Incidencias por articulo",
        _ => "Incidencias"
    };

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadThroughputAsync(), LoadCapacityAsync());
    }

    private async Task SetHistoryAsync(HistoryType type)
    {
        activeHistory = type;
        if (type == HistoryType.Capacity)
        {
            await Task.WhenAll(LoadThroughputAsync(), LoadCapacityAsync());
        }
        else
        {
            await LoadHistoryAsync();
        }
    }

    private async Task LoadHistoryAsync()
    {
        historyLoading = true;
        historyError = null;
        try
        {
            history = await Api.GetHistoryAsync(new HistoryQuery
            {
                Type = activeHistory,
                Period = StatisticsPeriod.Days
            });
        }
        catch (ApiException exception)
        {
            history = new();
            historyError = exception.Message;
        }
        finally
        {
            historyLoading = false;
        }
    }

    private async Task SetTopPeriodAsync(StatisticsPeriod period)
    {
        topPeriod = period;
        await LoadThroughputAsync();
    }

    private async Task SetBottomPeriodAsync(StatisticsPeriod period)
    {
        bottomPeriod = period;
        await LoadCapacityAsync();
    }

    private async Task LoadThroughputAsync()
    {
        topLoading = true;
        topError = null;
        try
        {
            throughputStatistics = await Api.GetCapacityStatisticsAsync(topPeriod);
        }
        catch (ApiException exception)
        {
            throughputStatistics = new();
            topError = exception.Message;
        }
        finally
        {
            topLoading = false;
        }
    }

    private async Task LoadCapacityAsync()
    {
        bottomLoading = true;
        bottomError = null;
        try
        {
            capacityStatistics = await Api.GetCapacityStatisticsAsync(bottomPeriod);
        }
        catch (ApiException exception)
        {
            capacityStatistics = new();
            bottomError = exception.Message;
        }
        finally
        {
            bottomLoading = false;
        }
    }
}
